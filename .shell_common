# Shared interactive shell settings for bash and zsh.

export EDITOR="${EDITOR:-nvim}"
export VISUAL="${VISUAL:-$EDITOR}"
export PAGER="${PAGER:-less}"
export LESS="${LESS:--FRX}"

path_prepend() {
    case ":$PATH:" in
        *":$1:"*) ;;
        *) [ -d "$1" ] && PATH="$1:$PATH" ;;
    esac
}

path_append() {
    case ":$PATH:" in
        *":$1:"*) ;;
        *) [ -d "$1" ] && PATH="$PATH:$1" ;;
    esac
}

path_prepend "$HOME/.local/bin"
path_prepend "$HOME/bin"
path_append "$HOME/go/bin"
export PATH

[ -r "$HOME/.local/bin/env" ] && . "$HOME/.local/bin/env"

if command -v nvim >/dev/null 2>&1; then
    alias vim='nvim'
fi

if ls --color=auto >/dev/null 2>&1; then
    alias ls='ls --color=auto'
elif ls -G >/dev/null 2>&1; then
    alias ls='ls -G'
fi

alias ll='ls -lh'
alias la='ls -A'
alias lla='ls -lAh'
if grep --color=auto '' /dev/null >/dev/null 2>&1; then
    alias grep='grep --color=auto'
fi
alias ..='cd ..'
alias ...='cd ../..'
alias gst='git status --short'
alias gl='git log --oneline --decorate --graph -20'
alias gd='git diff'

mkcd() {
    mkdir -p "$1" && cd "$1" || return
}

if command -v rg >/dev/null 2>&1; then
    if [ -n "${RIPGREP_CONFIG_PATH:-}" ] && [ ! -r "$RIPGREP_CONFIG_PATH" ]; then
        unset RIPGREP_CONFIG_PATH
    fi

    if [ -z "${RIPGREP_CONFIG_PATH:-}" ] && [ -r "$HOME/.ripgreprc" ]; then
        export RIPGREP_CONFIG_PATH="$HOME/.ripgreprc"
    fi
fi

if command -v bat >/dev/null 2>&1; then
    export BAT_THEME="${BAT_THEME:-GitHub}"
    export BAT_STYLE="${BAT_STYLE:-numbers,changes,header}"
elif command -v batcat >/dev/null 2>&1; then
    export BAT_THEME="${BAT_THEME:-GitHub}"
    export BAT_STYLE="${BAT_STYLE:-numbers,changes,header}"
    alias bat='batcat'
fi

if [ -z "${LS_COLORS:-}" ]; then
    export LS_COLORS="di=34:ln=35:so=36:pi=33:ex=32:bd=33:cd=33:su=31:sg=31:tw=34:ow=34:*.tar=31:*.tgz=31:*.zip=31:*.gz=31:*.xz=31:*.bz2=31:*.7z=31:*.rar=31:*.jpg=35:*.jpeg=35:*.png=35:*.gif=35:*.webp=35:*.svg=35:*.mp3=36:*.flac=36:*.ogg=36:*.mp4=36:*.mkv=36:*.mov=36"
fi

if ! command -v fd >/dev/null 2>&1 && command -v fdfind >/dev/null 2>&1; then
    alias fd='fdfind'
fi

if command -v fzf >/dev/null 2>&1; then
    fzf_light_opts="--color=light,fg:#202020,bg:#fffff5,hl:#0050ff,fg+:#000000,bg+:#eaffea,hl+:#7b0080,prompt:#006974,pointer:#7b0080,marker:#558855,spinner:#7c3c00,header:#6b7ca8,border:#558855,gutter:#fffff5,info:#7c3c00"
    case " ${FZF_DEFAULT_OPTS:-} " in
        *" $fzf_light_opts "*) ;;
        *) export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:+$FZF_DEFAULT_OPTS }$fzf_light_opts" ;;
    esac
    unset fzf_light_opts

    fzf_ignore_opts="--walker-skip .git,.svn,.hg,node_modules,.DS_Store,__pycache__,.cache"
    case " ${FZF_DEFAULT_OPTS:-} " in
        *" $fzf_ignore_opts "*) ;;
        *) export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:+$FZF_DEFAULT_OPTS }$fzf_ignore_opts" ;;
    esac
    unset fzf_ignore_opts
fi

if command -v direnv >/dev/null 2>&1; then
    eval "$(direnv hook "${ZSH_VERSION:+zsh}${BASH_VERSION:+bash}")"
fi

if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init "${ZSH_VERSION:+zsh}${BASH_VERSION:+bash}")"
fi
